    .nav-links a { color: var(--ink-soft); text-decoration: none; font-size: 0.88rem; transition: color 0.2s; }
    .nav-links a:hover { color: var(--accent); }
    .nav-toggle { display: none; background: none; border: none; font-size: 1.4rem; cursor: pointer; color: var(--ink); }
    .mobile-menu { display: none; flex-direction: column; position: fixed; top: var(--nav-h); left: 0; right: 0; background: var(--bg); border-bottom: 1px solid var(--surface-2); z-index: 99; }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { color: var(--ink); text-decoration: none; font-size: 1.1rem; padding: 0.85rem 2rem; border-bottom: 1px solid var(--surface-2); }
    .footer { background: var(--ink); color: rgba(255,255,255,0.55); padding: 2.5rem 2rem; }
    .footer-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
    .footer p { font-size: 0.85rem; }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a { color: rgba(255,255,255,0.45); text-decoration: none; font-size: 0.85rem; transition: color 0.2s; }
    .footer-links a:hover { color: #fff; }

    .blog-wrap { max-width: 1100px; margin: 0 auto; padding: calc(var(--nav-h) + 4rem) 2rem 6rem; }
    .eyebrow { font-family: var(--mono); font-size: 0.72rem; color: var(--accent); letter-spacing: 0.15em; text-transform: uppercase; display: block; margin-bottom: 1rem; }
    .blog-wrap h1 { font-family: var(--serif); font-size: clamp(2.5rem, 6vw, 4rem); color: var(--ink); margin-bottom: 0.75rem; }
    .blog-wrap h1 em { font-style: italic; color: var(--accent); }
    .blog-intro { color: var(--ink-soft); font-size: 1.05rem; max-width: 520px; margin-bottom: 3rem; }
    .notice { background: var(--accent-light); border-left: 3px solid var(--accent); border-radius: 0 8px 8px 0; padding: 1rem 1.25rem; margin-bottom: 2.5rem; font-size: 0.85rem; color: var(--ink-soft); }
    .notice strong { color: var(--accent-dark); }
    .post-list { display: flex; flex-direction: column; gap: 0; }
    .post-item { display: grid; grid-template-columns: 150px 1fr; gap: 2rem; padding: 2rem 0; border-top: 1px solid var(--surface-2); text-decoration: none; transition: background 0.15s; border-radius: 8px; margin: 0 -1rem; padding-left: 1rem; padding-right: 1rem; }
    .post-item:hover { background: var(--surface); }
    .post-meta-col { font-family: var(--mono); font-size: 0.73rem; color: var(--ink-muted); line-height: 1.9; padding-top: 0.3rem; }
    .post-pill { display: inline-block; background: var(--accent-light); color: var(--accent); font-size: 0.63rem; letter-spacing: 0.1em; padding: 0.2rem 0.55rem; border-radius: 4px; margin-top: 0.5rem; }
    .post-title { font-family: var(--serif); font-size: 1.4rem; color: var(--ink); margin-bottom: 0.5rem; line-height: 1.3; font-weight: 400; }
    .post-excerpt { font-size: 0.9rem; color: var(--ink-soft); line-height: 1.7; }
    .post-read { display: inline-block; margin-top: 0.75rem; font-size: 0.82rem; color: var(--accent); font-weight: 500; }
    @media (max-width: 960px) { .nav-links { display: none; } .nav-toggle { display: block; } }
    @media (max-width: 600px) { .post-item { grid-template-columns: 1fr; gap: 0.4rem; } }
